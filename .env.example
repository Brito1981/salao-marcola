# Copie este arquivo para ".env" e preencha com os dados do seu projeto Supabase.
# (No Supabase: Project Settings > API)

# URL do projeto (ex.: https://abcdxyz.supabase.co)
VITE_SUPABASE_URL=

# Chave pública / anon (Project Settings > API > Project API keys > anon public)
VITE_SUPABASE_ANON_KEY=
